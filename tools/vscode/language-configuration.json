{
  "comments": {
    "lineComment": "//"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] }
  ],
  "autoCloseBefore": ";:.,=}])>` \n\t",
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*.*(\\{[^}\"']*|\\([^)\"']*|\\[[^\\]\"']*)$",
    "decreaseIndentPattern": "^\\s*(\\s*\\/[/*].*|\\s*\\*.*|\\s*\\}.*|\\s*\\).*|\\s*\\]>.*)$"
  }
}
